<Page x:Class="BiometricEnrollmentApp.EmployeeAttendancePage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Employee Attendance"
      Background="#F1F5F9"
      FontFamily="Segoe UI">

    <Page.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="NavyBlueBrush"       Color="#0F172A"/>
        <SolidColorBrush x:Key="DarkTextBrush"        Color="#1E293B"/>
        <SolidColorBrush x:Key="MutedTextBrush"       Color="#64748B"/>
        <SolidColorBrush x:Key="SurfaceBrush"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PageBgBrush"          Color="#F1F5F9"/>

        <!-- Status Palette -->
        <SolidColorBrush x:Key="SuccessBgBrush"       Color="#F0FDF4"/>
        <SolidColorBrush x:Key="SuccessBorderBrush"   Color="#86EFAC"/>
        <SolidColorBrush x:Key="SuccessTextBrush"     Color="#15803D"/>
        <SolidColorBrush x:Key="SuccessSubBrush"      Color="#166534"/>

        <SolidColorBrush x:Key="WarningBgBrush"       Color="#FFFBEB"/>
        <SolidColorBrush x:Key="WarningBorderBrush"   Color="#FCD34D"/>
        <SolidColorBrush x:Key="WarningTextBrush"     Color="#B45309"/>
        <SolidColorBrush x:Key="WarningSubBrush"      Color="#92400E"/>

        <SolidColorBrush x:Key="ErrorBgBrush"         Color="#FFF1F2"/>
        <SolidColorBrush x:Key="ErrorBorderBrush"     Color="#FCA5A5"/>
        <SolidColorBrush x:Key="ErrorTextBrush"       Color="#B91C1C"/>
        <SolidColorBrush x:Key="ErrorSubBrush"        Color="#991B1B"/>

        <SolidColorBrush x:Key="InfoBgBrush"          Color="#EFF6FF"/>
        <SolidColorBrush x:Key="InfoBorderBrush"      Color="#93C5FD"/>
        <SolidColorBrush x:Key="InfoTextBrush"        Color="#1D4ED8"/>
        <SolidColorBrush x:Key="InfoSubBrush"         Color="#1E40AF"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="CardShadow"   BlurRadius="28" ShadowDepth="6"  Direction="270" Color="#000000" Opacity="0.07"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="10" ShadowDepth="2"  Direction="270" Color="#000000" Opacity="0.18"/>
        <DropShadowEffect x:Key="PhotoShadow"  BlurRadius="20" ShadowDepth="4"  Direction="270" Color="#000000" Opacity="0.12"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header bar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource NavyBlueBrush}" Effect="{StaticResource HeaderShadow}" Panel.ZIndex="10">
            <Grid Margin="28,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Kiosk label -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Kiosk Mode" Foreground="#94A3B8" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Date + Time -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderDateText" Text="Tue, May 05"
                               Foreground="#94A3B8" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="14,7">
                        <TextBlock x:Name="HeaderTimeText" Text="12:34 PM"
                                   FontWeight="Bold" Foreground="#60A5FA" FontSize="15"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Background="{StaticResource PageBgBrush}" Margin="32">

                <!-- Central card -->
                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="20"
                        Effect="{StaticResource CardShadow}"
                        BorderBrush="#E2E8F0" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Photo column -->
                            <ColumnDefinition Width="300"/>
                            <!-- Divider -->
                            <ColumnDefinition Width="1"/>
                            <!-- Info column -->
                            <ColumnDefinition Width="420"/>
                        </Grid.ColumnDefinitions>

                        <!-- ─────────────────────────────────────────────── -->
                        <!-- LEFT: Photo + scanner badge                     -->
                        <!-- ─────────────────────────────────────────────── -->
                        <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="20,0,0,20" Padding="36,40">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                <!-- Photo frame -->
                                <Border Width="200" Height="200"
                                        CornerRadius="16"
                                        BorderBrush="#E2E8F0" BorderThickness="2"
                                        ClipToBounds="True"
                                        Effect="{StaticResource PhotoShadow}"
                                        Background="#EFF6FF">
                                    <Grid>
                                        <Viewbox x:Name="DefaultUserIcon"
                                                 Width="80" Height="80"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Fill="#CBD5E1"
                                                  Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                        </Viewbox>
                                        <Image x:Name="EmployeePhoto"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Scanner active badge -->
                                <Border Background="White"
                                        BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="20" Padding="14,7"
                                        HorizontalAlignment="Center"
                                        Margin="0,20,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="9" Height="9" Fill="#10B981" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="InstructionText"
                                                   Text="Place finger to scan"
                                                   Foreground="#475569"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>

                        <!-- Vertical divider -->
                        <Rectangle Grid.Column="1" Fill="#E2E8F0"/>

                        <!-- ─────────────────────────────────────────────── -->
                        <!-- RIGHT: Employee info + status card              -->
                        <!-- ─────────────────────────────────────────────── -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="36,40">

                            <!-- Idle prompt (shown before scan) -->
                            <TextBlock x:Name="EmployeeNameText"
                                       Text="Awaiting scan..."
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource DarkTextBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="Visible"
                                       Margin="0,0,0,16"/>

                            <!-- ─── STATUS CARD ─────────────────────────── -->
                            <!-- Background/border are set from code-behind   -->
                            <Border x:Name="StatusPanel"
                                    Visibility="Collapsed"
                                    CornerRadius="14"
                                    BorderThickness="1.5"
                                    Padding="22,20"
                                    Margin="0,0,0,0">

                                <StackPanel>

                                    <!-- Row 1: Icon + Title -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock x:Name="StatusIcon"
                                                   Text="✔"
                                                   FontSize="26"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock x:Name="StatusMessage"
                                                   Text="Time In Recorded"
                                                   FontSize="22" FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Row 2: Description -->
                                    <TextBlock x:Name="StatusDetails"
                                               Text="Recorded at 08:00 AM"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"
                                               Visibility="Visible"/>

                                    <!-- Row 3: Extra info (next shift, etc.) -->
                                    <TextBlock x:Name="StatusExtra"
                                               Text=""
                                               FontSize="13"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"
                                               Visibility="Collapsed"/>

                                    <!-- Row 4: Guidance hint -->
                                    <TextBlock x:Name="StatusGuidance"
                                               Text=""
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Opacity="0.75"
                                               Margin="0,4,0,0"
                                               Visibility="Collapsed"/>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hidden clock elements (updated by code-behind) -->
                <TextBlock x:Name="CurrentTimeText" Visibility="Collapsed"/>
                <TextBlock x:Name="CurrentDateText" Visibility="Collapsed"/>

            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- FOOTER                                                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="0,11">
            <TextBlock Text="© 2026 SecureAttend Systems"
                       HorizontalAlignment="Center"
                       Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Page>
